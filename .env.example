# AutoDailyTask 環境変数設定ファイル
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# ── Slack 設定 ──────────────────────────────────────────────
# Slack Bot User OAuth Token
# 取得方法: https://api.slack.com/apps → OAuth & Permissions → Bot Token
# 必要なスコープ: files:write, channels:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# 通知先チャンネルID（チャンネル名ではなくID）
# 取得方法: Slackでチャンネルを右クリック → リンクをコピー → URLの末尾
SLACK_CHANNEL_ID=C0123456789
